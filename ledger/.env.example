# Required: PostgreSQL password
PG_PASSWORD=change-me-strong-random-here

# Public forum origin. Required when DiscourseConnect is enabled.
FORUM_BASE_URL=https://forum.example.com

# Public callback URL. Leave empty to use:
#   ${FORUM_BASE_URL}/wallet/auth/discourse/callback
WALLET_CALLBACK_URL=

# Host bind settings for the sidecar. The default works for a typical
# discourse_docker standalone install where the Discourse container can reach
# the host's docker0 gateway.
LEDGER_BIND_ADDR=172.17.0.1
LEDGER_LOCAL_BIND_ADDR=127.0.0.1
LEDGER_HOST_PORT=18080

# Required: 64-char hex Ed25519 PUBLIC key of the admin (= treasury account)
# Generate via:  docker compose run --rm --entrypoint ledger-admin sidecar keygen
# Then paste pubkey here, and store the matching private key offline / in a secret manager.
ADMIN_PUBKEY_HEX=

# Sidecar holds the admin PRIVATE key in this env var only when it needs to auto-sign reward txs
# or sign STH checkpoints / OpenTimestamps anchors. Leave empty if you only need public reads.
ADMIN_PRIV_KEY_HEX=

# Prefer split hot keys in production. These override ADMIN_PRIV_KEY_HEX for
# their own duties and let the treasury/admin key stay offline.
REWARD_PRIV_KEY_HEX=
STH_PRIV_KEY_HEX=

# OpenTimestamps calendar endpoint used by the admin UI and CLI anchor flow.
# The default public pool is gas-free and commits the digest into Bitcoin.
OTS_CALENDAR_URL=https://a.pool.opentimestamps.org/digest

# Optional comma-separated calendar allowlist for admin-triggered OTS anchors.
# The default OTS calendar and OTS_CALENDAR_URL are always allowed.
OTS_CALENDAR_ALLOWLIST=

# Per-sidecar in-memory token bucket. Leave empty for defaults: 600/min, burst 120.
WALLET_RATE_LIMIT_PER_MINUTE=
WALLET_RATE_LIMIT_BURST=

# Label for the treasury account created by genesis.
TREASURY_USERNAME=TREASURY

# Required for stable admin Web UI sessions; use `openssl rand -hex 32`.
ADMIN_SESSION_SECRET=

# DiscourseConnect (SSO) shared secret — set in Discourse Admin → Settings → DiscourseConnect Provider
# Used by sidecar to validate session cookies. Leave empty until M2.
DISCOURSE_CONNECT_SECRET=

# Discourse Webhook shared secret — set in Discourse Admin → API → Webhooks
# Used for HMAC-SHA256 validation of incoming events. Leave empty until M3.5.
DISCOURSE_WEBHOOK_SECRET=

# Dev only. Leave both empty in production.
# If WALLET_ALLOW_HEADER_AUTH=1, WALLET_DEV_HEADER_AUTH_TOKEN must be a random
# 32+ byte token and requests must include X-Wallet-Dev-Auth with that value.
WALLET_ALLOW_HEADER_AUTH=
WALLET_DEV_HEADER_AUTH_TOKEN=
